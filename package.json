{
  "name": "finapp",
  "version": "1.0.0",
  "description": "Personal Finance Management Application",
  "homepage": "https://github.com/peterlee42/FinApp#readme",
  "bugs": {
    "url": "https://github.com/peterlee42/FinApp/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/peterlee42/FinApp.git"
  },
  "license": "ISC",
  "author": "Peter Lee",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "start": "node ./src/index.js",
    "dev": "dotenv -e .env.development -- node --watch ./src/index.js",
    "prod": "dotenv -e .env.production -- node ./src/index.js",
    "dev:migrate": "dotenv -e .env.development -- prisma migrate dev",
    "prod:migrate": "dotenv -e .env.production -- prisma migrate deploy",
    "test": "jest",
    "lint": "eslint . --ext .js",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@prisma/client": "^6.16.1",
    "@prisma/extension-accelerate": "^2.0.2",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "cross-env": "^10.0.0",
    "dotenv": "^17.2.3",
    "dotenv-cli": "^10.0.0",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.34.0",
    "eslint": "^9.34.0",
    "globals": "^16.3.0",
    "jest": "^30.1.3",
    "morgan": "^1.10.1",
    "prettier": "^3.6.2",
    "prisma": "^6.16.2",
    "supertest": "^7.1.4"
  }
}
