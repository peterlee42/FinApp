// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =======================
// MODELS
// =======================

model User {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String    @unique
  firstName     String
  lastName      String
  password      String
  emailVerified Boolean   @default(false)
  failedLogins  Int       @default(0)
  lastLogin     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // ******Relationships*************
  accounts Account[]
  goals    Goal[]

  // ******Configs*************
  @@map("users")
}

model Account {
  id        String      @id @default(cuid())
  name      String
  type      AccountType
  balance   Decimal     @default(0.0)
  currency  Currency    @default(CAD)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id])

  // ******Relationships*************
  transactions Transaction[]

  // ******Configs*************
  @@map("accounts")
}

model Category {
  id        String          @id @default(cuid())
  name      String
  type      TransactionType
  icon      String?
  color     String?
  createdAt DateTime        @default(now())

  transactions Transaction[]
}

model Transaction {
  id          String          @id @default(cuid())
  description String
  amount      Decimal
  type        TransactionType
  date        DateTime        @default(now())

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  accountId String
  account   Account @relation(fields: [accountId], references: [id])
}

model Goal {
  id            String       @id @default(cuid())
  title         String
  targetAmount  Decimal
  currentAmount Decimal      @default(0.0) @db.Decimal(19, 2)
  priority      GoalPriority @default(MEDIUM)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  achieved      Boolean      @default(false)

  userId String
  user   User   @relation(fields: [userId], references: [id])
}

// =======================
// ENUMS
// =======================

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

enum AccountType {
  CASH
  DEBIT
  CREDIT
  SAVINGS
  INVESTMENT
  OTHER
}

enum GoalPriority {
  HIGH
  MEDIUM
  LOW
}

enum BudgetFrequency {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum Currency {
  CAD
  USD
  EUR
  GBP
  AUD
  JPY
  KRW
}
